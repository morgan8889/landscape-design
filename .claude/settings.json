{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npx playwright *)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm run typecheck*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx biome *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(git push -u origin *)",
      "Bash(git checkout -b *)",
      "Bash(git switch -c *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list *)",
      "Bash(gh api repos/*/*)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(chmod +x *)",
      "Bash(npx playwright install *)",
      "Bash(cp *)",
      "Bash(npx vite preview *)",
      "Bash(sleep *)",
      "Bash(pkill -f vite*)",
      "Bash(mv *)",
      "Bash(rm -f *)",
      "Bash(touch *)",
      "Bash(npm audit *)",
      "Bash(npx vitest *)",
      "Bash(npx vite *)",
      "Bash(git checkout *)",
      "Bash(git -c *)",
      "Bash(git -C *)",
      "Bash(git rm *)",
      "Bash(git stash *)",
      "Bash(git remote *)",
      "Bash(curl -sf *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(timeout *)",
      "Bash(which *)",
      "Bash(bash *)",
      "Bash(mkdir *)",
      "Bash(md5 *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(FULL_TESTS=*)",
      "Bash(SCREENSHOT_MAX_AGE_MINS=*)",
      "Bash(GIT_COMMITTER_NAME=*)",
      "Bash(GIT_AUTHOR_NAME=*)",
      "Bash(HUSKY=*)",
      "Bash(gh pr edit *)",
      "Bash(gh pr comment *)",
      "Bash(lsof *)",
      "Bash(rm -f /tmp/claude-session*)",
      "Bash(rm -f /tmp/claude-circuit*)",
      "Bash(stat *)",
      "Bash(ps *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/verify-before-commit.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": ".claude/hooks/circuit-breaker.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/review-enforcer.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/review-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-format.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-commit-review.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-init.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-stop.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
